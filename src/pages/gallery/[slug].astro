---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('gallery');
  return entries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout title={`${entry.data.title} - Gallery`}>
  <Header slot="header" />
  <div class="page-header">
    <div class="page-header-content">
      <a href="/gallery" class="back-button">← Back to Datasets</a>
      <h1>{entry.data.title}</h1>
      <p class="page-subtitle">{entry.data.date.toLocaleDateString('ko-KR')}</p>
    </div>
  </div>

  <section class="description">
      <Content />
  </section>

<section class="section gallery-section">
  <div class="container">
    <div class="image-grid">
      {entry.data.images?.map((img) => (
        <div class="image-item">
          <div class="img-box">
            <img src={img.src} alt={img.alt} title={img.alt} />
          </div>
          {img.alt && <p class="caption">{img.alt}</p>}
        </div>
      ))}
    </div>
  </div>
</section>
  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-header {
    min-height: 30vh;
    background-image: url('/ewha.gif');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    color: white;
    position: relative;
    padding: 2.5rem 0;
  }

  .page-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: 
      repeating-linear-gradient(
        0deg,
        rgba(255, 255, 255, 0.08) 0px,
        transparent 1px,
        transparent 40px,
        rgba(255, 255, 255, 0.08) 41px
      ),
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.08) 0px,
        transparent 1px,
        transparent 40px,
        rgba(255, 255, 255, 0.08) 41px
      );
    pointer-events: none;
    z-index: 1;
  }

  .page-header-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1000px;
    padding: 0 60px;
    text-align: left;
  }

  .page-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.15rem;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .page-subtitle {
    font-size: 0.9rem;
    font-weight: 300;
    opacity: 0.95;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
    margin: 0;
  }

  .back-button {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 300;
    margin-bottom: 1.2rem;
    transition: all 0.2s ease;
    letter-spacing: 0.3px;
  }

  .back-button:hover {
    color: white;
    transform: translateX(-3px);
  }

  .description { 
    margin-bottom: 15px; 
    line-height: 1.7; 
    color: #444;
    font-size: 1rem;
  }

  .image-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, 320px);
    gap: 15px;
    justify-content: center; 
    align-items: start;
  }

  .image-item {
    width: 320px;
    border: 1px solid #f0f0f0;
    border-radius: 8px;
    background: #fff;
    overflow: hidden;
    transition: box-shadow 0.3s ease;
  }

  .img-box {
    width: 100%;
    height: auto; 
    overflow: hidden;
    background: #f9f9f9;
  }

  .img-box img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    transition: transform 0.4s ease;
  }

  .img-box img:hover {
    transform: scale(1.08);
  }

  .caption {
    padding: 8px;
    font-size: 0.75rem;
    color: #666;
    text-align: center;
    background: #fafafa;
    margin: 0;
    /* 텍스트가 너무 길면 잘라냄 */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* 모바일 대응: 화면이 아주 좁아지면 중앙 정렬 */
  @media (max-width: 500px) {
    .image-grid { justify-content: center; }
  }
</style>

